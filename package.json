{
  "name": "ts-todo-app",
  "version": "0.1.0",
  "description": "todo app for portfolio",
  "main": "dist/app/index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "dev": "ts-node src/app/index.ts",
    "dev:watch": "ts-node-dev --watch 'src/app/**/*.ts' --respawn src/app/index.ts",
    "snippet:watch": "ts-node-dev --respawn src/app/dev.ts",
    "clean": "rimraf dist/*",
    "tsc": "tsc",
    "build": "build",
    "start": "node ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/about-yy/ts-todo-app.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/about-yy/ts-todo-app/issues"
  },
  "homepage": "https://github.com/about-yy/ts-todo-app#readme",
  "dependencies": {
    "@types/dotenv": "^8.2.0",
    "@types/express": "^4.17.11",
    "@types/pg": "^7.14.9",
    "dotenv": "^8.2.0",
    "express": "^4.17.1",
    "pg": "^8.5.1",
    "typescript": "^4.1.3"
  },
  "devDependencies": {
    "@types/jest": "^26.0.20",
    "@types/node": "^14.14.22",
    "jest": "^26.6.3",
    "npm-run-all": "^4.1.5",
    "rimraf": "^2.7.1",
    "ts-jest": "^26.4.4",
    "ts-node": "^9.1.1",
    "ts-node-dev": "^1.1.1"
  }
}
