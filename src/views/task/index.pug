extends ../layout.pug
block variable
    - bodyClass = "task"
block styles 
    link(rel="stylesheet", href="/css/task.css")
block title 
    |PRIVATE TASK MANAGER
block body
    #ts-todo-app
        .head-banner 
            | banner
        header
            h2 タスク一覧
        .task-list 
            - for (let i=0; i<10; i++)
                .task-title 
                    p task name 
                .task-control-button
                    button(type="submit") 詳細・編集
                    button(type="submit") 更新
                    button(type="submit") 削除
        .task-input-form 
            label(for="name")
            input(type="text", name="name")
            button(type="submit") 保存
        footer.center.block.text フッター
